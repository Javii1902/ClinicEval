<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clineval.cliniceval.DashboardController"
      spacing="18"
      styleClass="dashboard-page">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Dashboard" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Export to Excel" styleClass="primary-button" onAction="#handleExportToExcel"/>
    </HBox>

    <HBox spacing="16">
        <VBox spacing="6" styleClass="summary-card" HBox.hgrow="ALWAYS">
            <Label text="Overall Compliance" styleClass="summary-title"/>
            <Label fx:id="overallComplianceLabel" text="0.00%" styleClass="summary-value"/>
        </VBox>

        <VBox spacing="6" styleClass="summary-card" HBox.hgrow="ALWAYS">
            <Label text="Compliant Clinics" styleClass="summary-title"/>
            <Label fx:id="compliantClinicsLabel" text="0" styleClass="summary-value"/>
        </VBox>

        <VBox spacing="6" styleClass="summary-card" HBox.hgrow="ALWAYS">
            <Label text="Non-Compliant Clinics" styleClass="summary-title"/>
            <Label fx:id="nonCompliantClinicsLabel" text="0" styleClass="summary-value"/>
        </VBox>
    </HBox>

    <VBox spacing="10" styleClass="card">
        <Label text="Clinic Compliance Status" styleClass="card-title"/>
        <BarChart fx:id="clinicStatusChart" categoryGap="20" legendVisible="false" prefHeight="320">
            <xAxis>
                <CategoryAxis label="Status"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Number of Clinics"/>
            </yAxis>
        </BarChart>
    </VBox>

    <VBox spacing="10" styleClass="card">
        <Label text="Clinic Compliance Table" styleClass="card-title"/>
        <TableView fx:id="clinicComplianceTable" prefHeight="240" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="clinicNameColumn" text="Clinic Name" prefWidth="260"/>
                <TableColumn fx:id="clinicComplianceColumn" text="Compliance Percentage" prefWidth="170"/>
                <TableColumn fx:id="clinicYesCountColumn" text="Yes" prefWidth="90"/>
                <TableColumn fx:id="clinicNoCountColumn" text="No" prefWidth="90"/>
                <TableColumn fx:id="clinicNaCountColumn" text="N/A" prefWidth="90"/>
            </columns>
        </TableView>
    </VBox>

    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="Question Compliance Table" styleClass="card-title"/>
        <TableView fx:id="questionComplianceTable" prefHeight="320" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="questionColumn" text="Question" prefWidth="240"/>
                <TableColumn fx:id="questionComplianceColumn" text="Compliance Percentage" prefWidth="180"/>
                <TableColumn fx:id="yesCountColumn" text="Yes" prefWidth="100"/>
                <TableColumn fx:id="noCountColumn" text="No" prefWidth="100"/>
                <TableColumn fx:id="naCountColumn" text="N/A" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>
</VBox>