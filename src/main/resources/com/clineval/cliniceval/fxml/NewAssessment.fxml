<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clineval.cliniceval.NewAssessmentController"
      spacing="16"
      styleClass="assessment-page">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="New Assessment" styleClass="page-title"/>

    <GridPane hgap="14" vgap="14">
        <columnConstraints>
            <ColumnConstraints prefWidth="140"/>
            <ColumnConstraints prefWidth="320"/>
            <ColumnConstraints prefWidth="140"/>
            <ColumnConstraints prefWidth="220"/>
        </columnConstraints>

        <Label text="Clinic Name:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="clinicComboBox"
                  promptText="Select existing clinic or type a new one"
                  prefWidth="300"
                  GridPane.rowIndex="0"
                  GridPane.columnIndex="1"/>

        <Label text="Assessment Date:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <DatePicker fx:id="assessmentDatePicker"
                    prefWidth="180"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="3"/>
    </GridPane>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="assessment-scroll">
        <content>
            <VBox spacing="14" styleClass="assessment-content">

                <GridPane hgap="12" vgap="12" styleClass="assessment-grid">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="360"/>
                        <ColumnConstraints prefWidth="240"/>
                        <ColumnConstraints prefWidth="320"/>
                    </columnConstraints>

                    <Label text="Question" styleClass="table-header" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label text="Response" styleClass="table-header" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Comments" styleClass="table-header" GridPane.rowIndex="0" GridPane.columnIndex="2"/>

                    <Label text="Question 1" styleClass="question-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <RadioButton fx:id="q1YesRadio" text="Yes"/>
                        <RadioButton fx:id="q1NoRadio" text="No"/>
                        <RadioButton fx:id="q1NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q1CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

                    <Label text="Question 2" styleClass="question-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="2" GridPane.columnIndex="1">
                        <RadioButton fx:id="q2YesRadio" text="Yes"/>
                        <RadioButton fx:id="q2NoRadio" text="No"/>
                        <RadioButton fx:id="q2NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q2CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="2"/>

                    <Label text="Question 3" styleClass="question-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="3" GridPane.columnIndex="1">
                        <RadioButton fx:id="q3YesRadio" text="Yes"/>
                        <RadioButton fx:id="q3NoRadio" text="No"/>
                        <RadioButton fx:id="q3NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q3CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="2"/>

                    <Label text="Question 4" styleClass="question-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="4" GridPane.columnIndex="1">
                        <RadioButton fx:id="q4YesRadio" text="Yes"/>
                        <RadioButton fx:id="q4NoRadio" text="No"/>
                        <RadioButton fx:id="q4NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q4CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="2"/>

                    <Label text="Question 5" styleClass="question-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="5" GridPane.columnIndex="1">
                        <RadioButton fx:id="q5YesRadio" text="Yes"/>
                        <RadioButton fx:id="q5NoRadio" text="No"/>
                        <RadioButton fx:id="q5NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q5CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="5" GridPane.columnIndex="2"/>

                    <Label text="Question 6" styleClass="question-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="6" GridPane.columnIndex="1">
                        <RadioButton fx:id="q6YesRadio" text="Yes"/>
                        <RadioButton fx:id="q6NoRadio" text="No"/>
                        <RadioButton fx:id="q6NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q6CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="6" GridPane.columnIndex="2"/>

                    <Label text="Question 7" styleClass="question-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="7" GridPane.columnIndex="1">
                        <RadioButton fx:id="q7YesRadio" text="Yes"/>
                        <RadioButton fx:id="q7NoRadio" text="No"/>
                        <RadioButton fx:id="q7NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q7CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="7" GridPane.columnIndex="2"/>

                    <Label text="Question 8" styleClass="question-label" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="8" GridPane.columnIndex="1">
                        <RadioButton fx:id="q8YesRadio" text="Yes"/>
                        <RadioButton fx:id="q8NoRadio" text="No"/>
                        <RadioButton fx:id="q8NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q8CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="8" GridPane.columnIndex="2"/>

                    <Label text="Question 9" styleClass="question-label" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="9" GridPane.columnIndex="1">
                        <RadioButton fx:id="q9YesRadio" text="Yes"/>
                        <RadioButton fx:id="q9NoRadio" text="No"/>
                        <RadioButton fx:id="q9NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q9CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="9" GridPane.columnIndex="2"/>

                    <Label text="Question 10" styleClass="question-label" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="10" GridPane.columnIndex="1">
                        <RadioButton fx:id="q10YesRadio" text="Yes"/>
                        <RadioButton fx:id="q10NoRadio" text="No"/>
                        <RadioButton fx:id="q10NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q10CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="10" GridPane.columnIndex="2"/>

                    <Label text="Question 11" styleClass="question-label" GridPane.rowIndex="11" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="11" GridPane.columnIndex="1">
                        <RadioButton fx:id="q11YesRadio" text="Yes"/>
                        <RadioButton fx:id="q11NoRadio" text="No"/>
                        <RadioButton fx:id="q11NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q11CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="11" GridPane.columnIndex="2"/>

                    <Label text="Question 12" styleClass="question-label" GridPane.rowIndex="12" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="12" GridPane.columnIndex="1">
                        <RadioButton fx:id="q12YesRadio" text="Yes"/>
                        <RadioButton fx:id="q12NoRadio" text="No"/>
                        <RadioButton fx:id="q12NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q12CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="12" GridPane.columnIndex="2"/>

                    <Label text="Question 13" styleClass="question-label" GridPane.rowIndex="13" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="13" GridPane.columnIndex="1">
                        <RadioButton fx:id="q13YesRadio" text="Yes"/>
                        <RadioButton fx:id="q13NoRadio" text="No"/>
                        <RadioButton fx:id="q13NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q13CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="13" GridPane.columnIndex="2"/>

                    <Label text="Question 14" styleClass="question-label" GridPane.rowIndex="14" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="14" GridPane.columnIndex="1">
                        <RadioButton fx:id="q14YesRadio" text="Yes"/>
                        <RadioButton fx:id="q14NoRadio" text="No"/>
                        <RadioButton fx:id="q14NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q14CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="14" GridPane.columnIndex="2"/>

                    <Label text="Question 15" styleClass="question-label" GridPane.rowIndex="15" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="15" GridPane.columnIndex="1">
                        <RadioButton fx:id="q15YesRadio" text="Yes"/>
                        <RadioButton fx:id="q15NoRadio" text="No"/>
                        <RadioButton fx:id="q15NaRadio" text="N/A"/>
                    </HBox>
                    <TextArea fx:id="q15CommentArea" prefRowCount="2" wrapText="true" GridPane.rowIndex="15" GridPane.columnIndex="2"/>
                </GridPane>
            </VBox>
        </content>
    </ScrollPane>

    <VBox spacing="8">
        <Label text="Overall Comments" styleClass="form-label"/>
        <TextArea fx:id="overallCommentsArea" prefRowCount="4" wrapText="true"/>
    </VBox>

    <HBox spacing="12">
        <Button text="Save Assessment" styleClass="primary-button" onAction="#saveAssessment"/>
        <Button text="Clear Form" styleClass="nav-button" onAction="#clearForm"/>
    </HBox>
</VBox>